# =============================================================================
# DiGiFaMaR — environment variables (EXAMPLE / documentation)
#
# NOTE: the real `.env` in this repo is auto-generated and managed by Lovable
# Cloud. It contains ONLY publishable, browser-safe config (Supabase anon/
# publishable keys + the referrer-locked Google Maps browser key) and is
# rewritten by the platform on each sync — do not hand-edit or delete it.
#
# All PRIVATE secrets (service_role, Anthropic, Escrow.com, Vonage, Lovable,
# cron, server Google Maps key, etc.) live in the Lovable Cloud secret store
# (Project Settings -> Backend -> Secrets) and are injected server-side at
# runtime — they are NEVER written to `.env`.
#
# This file just documents every variable the code reads so a developer knows
# what to provision. Vars prefixed with VITE_ are exposed to the browser bundle
# (public); everything else is server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — client (public, browser-exposed; managed in `.env` by Lovable)
# -----------------------------------------------------------------------------
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"

# Google Maps — browser key (public; restrict by HTTP referrer + API in GCP)
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_BROWSER_KEY="your-google-maps-browser-key"
VITE_LOVABLE_CONNECTOR_GOOGLE_MAPS_TRACKING_ID="your-google-maps-tracking-id"

# -----------------------------------------------------------------------------
# Supabase — server (publishable values re-read server-side; managed by Lovable)
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_ID="your-project-ref"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-publishable-key"

# =============================================================================
# The values below are SECRETS. They live in the Lovable Cloud secret store,
# NOT in `.env`. Listed here only so developers know what the app expects.
# =============================================================================

# service_role JWT — bypasses RLS. SERVER ONLY.
SUPABASE_SERVICE_ROLE_KEY="managed-in-lovable-secret-store"

# Anthropic (Claude) — AI Farm Assistant
ANTHROPIC_API_KEY="managed-in-lovable-secret-store"
# Optional; defaults to claude-sonnet-4-6 in code if unset.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Google Maps — server key (server-side geocoding/directions)
GOOGLE_MAPS_API_KEY="managed-in-lovable-secret-store"

# Escrow.com — payment/escrow integration
ESCROW_COM_EMAIL="managed-in-lovable-secret-store"
ESCROW_COM_API_KEY="managed-in-lovable-secret-store"

# Vonage — SMS (escrow delivery OTP / notifications)
VONAGE_API_KEY="managed-in-lovable-secret-store"
VONAGE_API_SECRET="managed-in-lovable-secret-store"
VONAGE_FROM="your-vonage-sender-id-or-number"

# Lovable — platform connector
LOVABLE_API_KEY="managed-in-lovable-secret-store"

# Cron / scheduled jobs — shared secret guarding cron endpoints
CRON_SECRET="managed-in-lovable-secret-store"
